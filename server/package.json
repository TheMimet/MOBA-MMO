{
  "name": "moba-mmo-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API for MOBA-MMO",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-db.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-local-db.ps1",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^7.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
