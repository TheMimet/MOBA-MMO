PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info
APP_ENV=development
AUTH_ADMIN_RECOVERY_SECRET=replace-with-local-admin-recovery-secret
# Optional comma-separated usernames auto-promoted to admin on login/register.
AUTH_ADMIN_USERNAMES=
AUTH_TOKEN_SECRET=replace-with-local-auth-token-secret
OPS_ADMIN_SECRET=replace-with-local-ops-admin-secret
# Local/dev can keep ops read endpoints open. Production must keep this true.
OPS_REQUIRE_ADMIN_SECRET=false
OPS_AUDIT_RETENTION_DAYS=90
# Set 0 to disable automatic audit cleanup. Default is every 6 hours.
OPS_AUDIT_PRUNE_INTERVAL_SECONDS=21600
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH_LOGIN_LOCKOUT_THRESHOLD=5
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
AUTH_PASSWORD_RESET_DELIVERY_PROVIDER=response
# Set 0 to disable automatic retry of failed password reset deliveries.
AUTH_PASSWORD_RESET_DELIVERY_RETRY_INTERVAL_SECONDS=300
AUTH_PASSWORD_RESET_DELIVERY_RETENTION_DAYS=14
AUTH_PASSWORD_RESET_WEBHOOK_URL=
AUTH_PASSWORD_RESET_WEBHOOK_SECRET=
# Local/dev can expose the reset token in API responses because there is no email provider yet. Production must keep this false.
AUTH_PASSWORD_RESET_EXPOSE_TOKEN=true
# Local/dev can keep legacy username-only login for the current UE bridge. Production must keep this false.
AUTH_ALLOW_LEGACY_USERNAME_LOGIN=true
DATABASE_URL="postgresql://mobammo_app:mobammo_app_pw@127.0.0.1:5433/mobammo?schema=public"
SESSION_SERVER_HOST=127.0.0.1
SESSION_SERVER_PORT=7777
SESSION_SERVER_MAP=/Game/ThirdPerson/Lvl_ThirdPerson
SESSION_SERVER_SECRET=replace-with-local-session-server-secret
# Optional comma-separated list used during secret rotation. Keep empty locally.
SESSION_SERVER_SECRET_PREVIOUS=
SESSION_TIMEOUT_SECONDS=120
