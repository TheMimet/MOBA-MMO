generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id            String             @id @default(cuid())
  username      String             @unique
  role          String             @default("player")
  passwordHash  String?
  failedLoginCount Int              @default(0)
  lockedUntil   DateTime?
  lastFailedLoginAt DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  characters    Character[]
  refreshTokens AuthRefreshToken[]
  passwordResetTokens AuthPasswordResetToken[]
  passwordResetDeliveries AuthPasswordResetDelivery[]
}

model AuthRefreshToken {
  id        String    @id @default(cuid())
  accountId String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AuthPasswordResetToken {
  id         String    @id @default(cuid())
  accountId  String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  delivery   AuthPasswordResetDelivery?

  @@index([accountId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model AuthPasswordResetDelivery {
  id                 String   @id @default(cuid())
  accountId          String
  resetTokenId       String   @unique
  provider           String
  status             String
  attemptCount       Int      @default(0)
  encryptedTokenJson String
  lastStatusCode     Int?
  lastError          String?
  nextAttemptAt      DateTime?
  deliveredAt        DateTime?
  expiresAt          DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  resetToken         AuthPasswordResetToken @relation(fields: [resetTokenId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([status])
  @@index([nextAttemptAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model Character {
  id          String          @id @default(cuid())
  accountId   String
  name        String
  classId     String
  level       Int             @default(1)
  experience  Int             @default(0)
  positionX      Float           @default(0)
  positionY      Float           @default(0)
  positionZ      Float           @default(0)
  presetId       Int             @default(4)
  colorIndex     Int             @default(0)
  shade          Int             @default(58)
  transparent    Int             @default(18)
  textureDetail  Int             @default(88)
  saveSequence   BigInt          @default(0)
  createdAt      DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  stats       CharacterStats?
  inventory   InventoryItem[]
  questStates QuestState[]
  activeSession CharacterSession?

  @@unique([accountId, name])
}

model CharacterSession {
  id          String    @id
  characterId String    @unique
  status      String    @default("active")
  startedAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterStats {
  id          String    @id @default(cuid())
  characterId String    @unique
  hp          Int       @default(100)
  maxHp       Int       @default(100)
  mana        Int       @default(50)
  maxMana     Int       @default(50)
  killCount   Int       @default(0)
  deathCount  Int       @default(0)
  gold        Int       @default(0)
  attack      Int       @default(10)
  defense     Int       @default(5)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id          String    @id @default(cuid())
  characterId String
  itemId      String
  quantity    Int       @default(1)
  slotIndex   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}

model QuestState {
  id            String    @id @default(cuid())
  characterId   String
  questId       String
  status        String
  progressValue Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, questId])
}

model PersistenceTelemetry {
  id                 String    @id
  saveAccepted       Int       @default(0)
  staleIgnored       Int       @default(0)
  rejected           Int       @default(0)
  timedOut           Int       @default(0)
  reconnectAttempted Int       @default(0)
  heartbeatAccepted  Int       @default(0)
  sessionStarted     Int       @default(0)
  sessionEnded       Int       @default(0)
  lastEventAt        DateTime?
  updatedAt          DateTime  @updatedAt
}

model PersistenceEvent {
  id           String   @id @default(cuid())
  eventType    String
  characterId  String?
  sessionId    String?
  statusCode   Int?
  errorCode    String?
  message      String?
  metadataJson String?
  occurredAt   DateTime @default(now())

  @@index([occurredAt])
  @@index([eventType])
  @@index([characterId])
  @@index([sessionId])
}

model OpsAuditEvent {
  id             String   @id @default(cuid())
  action         String
  actorType      String
  actorAccountId String?
  actorUsername  String?
  status         String
  target         String?
  message        String?
  metadataJson   String?
  occurredAt     DateTime @default(now())

  @@index([occurredAt])
  @@index([action])
  @@index([actorAccountId])
  @@index([status])
}
